# Supabase — https://app.supabase.com/project/{id}/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# サーバーサイドのみ。NEXT_PUBLIC_ を付けない（RLSバイパス防止）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Slack — https://api.slack.com/apps/{id}
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_BOT_USER_ID=U0XXXXXXXX
# 管理画面のエラー詳細から Slack スレッドを開くためのワークスペース URL（任意。未設定ならリンク非表示）
# SLACK_WORKSPACE_URL=https://your-workspace.slack.com

# LLM — プロバイダ非依存（OpenAI 互換 API）。プロバイダは未確定でも env の差し替えだけで切替可能。
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1  （モデル例: deepseek/deepseek-chat, openai/gpt-4o-mini）
#   DeepSeek:   LLM_BASE_URL=https://api.deepseek.com      （モデル例: deepseek-chat）
#   OpenAI:     LLM_BASE_URL=https://api.openai.com/v1     （モデル例: gpt-4o-mini, gpt-4o）
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_DEFAULT=deepseek/deepseek-chat
LLM_MODEL_COMPLEX=openai/gpt-4o
# Anthropic 直アダプタを使う場合のみ（OpenAI 互換経由なら不要）
# ANTHROPIC_API_KEY=sk-ant-your-api-key

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com
